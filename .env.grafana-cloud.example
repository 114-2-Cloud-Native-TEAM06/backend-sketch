# Grafana Cloud (free tier) — ship observability to the cloud instead of a
# local stack. Copy this file to `.env` (same folder as docker-compose.yml),
# fill in your values, then:  docker compose up -d app
#
#   cp .env.grafana-cloud.example .env      # (PowerShell: Copy-Item ... .env)
#
# `.env` is gitignored — NEVER commit real tokens.
# With these set you do NOT need the local stack (observability/docker-compose.yml).

# ── Traces / Metrics / Logs — Grafana Cloud OTLP ──
# Grafana Cloud → your stack → "OTLP" / "Configure OpenTelemetry".
# That page gives you the exact endpoint + the Authorization header to paste here.
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-<REGION>.grafana.net/otlp
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# Format: Authorization=Basic <base64(InstanceID:Token)>  (Grafana Cloud shows this string)
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <BASE64_OF_INSTANCEID:TOKEN>

# ── Profiles — Grafana Cloud Pyroscope ──
# Grafana Cloud → Pyroscope / Profiles → connection details + a token.
PYROSCOPE_SERVER_ADDRESS=https://profiles-prod-<REGION>.grafana.net
PYROSCOPE_BASIC_AUTH_USER=<PYROSCOPE_INSTANCE_OR_USER_ID>
PYROSCOPE_BASIC_AUTH_PASSWORD=<GRAFANA_CLOUD_TOKEN_WITH_profiles:write>
