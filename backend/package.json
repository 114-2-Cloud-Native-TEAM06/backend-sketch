{
  "name": "im-backend",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:all": "tsx watch src/index.ts",
    "dev:chat": "tsx watch services/chat-service/src/main.ts",
    "dev:user": "tsx watch services/user-service/src/main.ts",
    "dev:realtime": "tsx watch services/realtime-service/src/main.ts",
    "dev:writer": "tsx watch services/message-writer-service/src/main.ts",
    "dev:notification": "tsx watch services/notification-service/src/main.ts",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:coverage": "vitest run --config vitest.unit.config.ts --coverage && vitest run --config vitest.integration.config.ts --coverage",
    "load:seed": "tsx scripts/seed-load-test.ts",
    "load:ws": "docker run --rm -i --network host -v ./load-tests:/scripts grafana/k6 run /scripts/ws-1000-msgs.k6.js",
    "load:ws:bounded": "docker run --rm -i --network host -v ./load-tests:/scripts grafana/k6 run /scripts/ws-bounded-pending.k6.js",
    "load:nats": "tsx scripts/nats-load-message-writes.ts",
    "load:snapshot": "tsx scripts/load-test-snapshot.ts",
    "start": "node --loader ts-node/esm src/index.ts",
    "db:init": "docker compose -f ../compose.api.yml exec user-service npx prisma migrate dev --name init",
    "db:studio": "docker compose -f ../compose.api.yml exec user-service npx prisma studio --hostname 0.0.0.0",
    "db:setup": "docker compose -f ../compose.api.yml exec user-service npx prisma migrate deploy && docker compose -f ../compose.api.yml exec user-service npx prisma generate && docker compose -f ../compose.api.yml restart user-service chat-service notification-service"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.218.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@prisma/client": "^5.0.0",
    "@pyroscope/nodejs": "^0.4.11",
    "bcryptjs": "^2.4.3",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "jsonwebtoken": "^9.0.0",
    "nats": "^2.29.3",
    "pino": "^10.3.1",
    "pino-opentelemetry-transport": "^3.0.0",
    "redis": "^4.6.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.10.0",
    "@types/ws": "^8.5.13",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^8.55.0",
    "nodemon": "^3.0.0",
    "prisma": "^5.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.5"
  }
}
