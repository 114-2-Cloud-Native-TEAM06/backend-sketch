{
  "name": "im-backend",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --ext ts,js,json --exec \"tsx --import ./src/instrumentation.ts src/index.ts\"",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:coverage": "vitest run --config vitest.unit.config.ts --coverage && vitest run --config vitest.integration.config.ts --coverage",
    "start": "tsx --import ./src/instrumentation.ts src/index.ts",
    "db:init": "docker compose exec app npx prisma migrate dev --name init",
    "db:studio": "docker compose exec app npx prisma studio --hostname 0.0.0.0",
    "db:setup": "docker compose exec app npx prisma migrate deploy && docker compose exec app npx prisma generate && docker compose restart app"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.218.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@prisma/client": "^5.0.0",
    "@prisma/instrumentation": "^5.22.0",
    "@pyroscope/nodejs": "^0.4.11",
    "bcryptjs": "^2.4.3",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "jsonwebtoken": "^9.0.0",
    "pino": "^10.3.1",
    "pino-opentelemetry-transport": "^3.0.0",
    "redis": "^4.6.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.10.0",
    "@types/ws": "^8.5.13",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^8.55.0",
    "nodemon": "^3.0.0",
    "prisma": "^5.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.5"
  }
}
