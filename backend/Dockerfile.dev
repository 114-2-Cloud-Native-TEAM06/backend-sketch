FROM node:20-alpine

WORKDIR /app

COPY package*.json ./
COPY prisma ./prisma
RUN apk add --no-cache openssl

RUN npm install

# Exec tsx directly (no `npx` hop) so SIGTERM reaches the app and the graceful
# telemetry flush in src/index.ts runs on container stop.
CMD ["./node_modules/.bin/tsx", "watch", "--import", "./src/instrumentation.ts", "src/index.ts"]
