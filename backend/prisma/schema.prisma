generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(uuid())
  username    String   @unique
  displayName String
  email       String   @unique
  password    String
  createdAt   DateTime @default(now())

  memberships   RoomMember[]
  messages      Message[]
}

model Room {
  id             String   @id @default(uuid())
  name           String?
  isGroup        Boolean  @default(false)
  createdAt      DateTime @default(now())
  lastMessageAt  DateTime @default(now())
  nextMessageSeq BigInt   @default(1)

  members       RoomMember[]
  messages      Message[]

  @@index([lastMessageAt])
}

model RoomMember {
  userId   String
  roomId   String
  joinedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  room Room @relation(fields: [roomId], references: [id])

  @@id([userId, roomId])
}

model Message {
  id           String   @id @default(uuid())
  content      String
  createdAt    DateTime @default(now())
  requestId    String?
  roomSequence BigInt
  status       MessageStatus @default(PERSISTED)
  persistedAt  DateTime @default(now())
  fanoutedAt   DateTime?
  failedAt     DateTime?
  failureReason String?

  senderId String
  roomId   String

  sender  User            @relation(fields: [senderId], references: [id])
  room    Room            @relation(fields: [roomId], references: [id])
  outbox  MessageOutbox[]

  @@index([roomId, createdAt])
  @@index([roomId, roomSequence])
  @@unique([roomId, roomSequence])
  @@unique([senderId, requestId])
}

enum MessageStatus {
  PERSISTED
  FANOUTED
  FANOUT_FAILED
}

enum MessageOutboxStatus {
  PENDING
  PUBLISHING
  PUBLISHED
  FAILED
}

model MessageOutbox {
  id                 String              @id @default(uuid())
  eventType          String
  messageId          String
  status             MessageOutboxStatus @default(PENDING)
  attempts           Int                 @default(0)
  nextAttemptAt      DateTime?
  lockedAt           DateTime?
  publishedAt        DateTime?
  failureReason      String?
  originConnectionId String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  message Message @relation(fields: [messageId], references: [id])

  @@unique([eventType, messageId])
  @@index([status, nextAttemptAt])
  @@index([messageId])
}
