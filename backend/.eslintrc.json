{
  "env": {
    "node": true,
    "es2021": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "semi": ["warn", "always"],
    "comma-dangle": ["warn", "always-multiline"],
    "no-unused-vars": "warn",
    "quotes": ["warn", "single"]
  }
}
