# Observability config — copy to `.env.observability` and fill with your
# Grafana Cloud values. The real file is gitignored; never commit secrets.
# All services load it (see docker-compose.yml env_file on the base anchor).

# ── OTLP: traces + metrics + logs → Grafana Cloud ─────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-<region>.grafana.net/otlp
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64(otlp-instance-id:token)>
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# ── Pyroscope: profiles → Grafana Cloud ───────────────────────────────────────
PYROSCOPE_SERVER_ADDRESS=https://profiles-prod-<region>.grafana.net
PYROSCOPE_BASIC_AUTH_USER=<pyroscope-instance-id>
PYROSCOPE_BASIC_AUTH_PASSWORD=<token-with-profiles:write>

# ── Toggles ───────────────────────────────────────────────────────────────────
OBSERVABILITY_ENABLED=true     # set false to turn ALL telemetry off
# PROFILING_ENABLED=true       # set false to disable only Pyroscope profiling
# DB_SLOW_QUERY_MS=100         # slow-query log threshold
